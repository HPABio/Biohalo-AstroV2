---
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "@workspace/ui/components/card"
import { Badge } from "@workspace/ui/components/badge"

import { LightRays } from "@workspace/ui/components/light-rays.tsx"
import type { View } from "lucide-react"

const features = [
  {
    title: "Non-Toxic",
    description:
      "Our compounds protect surfaces without releasing toxic substances into marine environments.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: "Biodegradable",
    description:
      "OECD 301B certified biodegradability ensures zero persistent environmental impact.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22c1.25-1.25 2.5-2.5 4-3.5 1.5-1 3-1.5 4.5-1.5 1.5 0 3 .5 4.5 1.5 1.5 1 3 2.25 4 3.5"/><path d="M12 2v10"/><path d="M8 6c2.5 0 4 1.5 4 4"/><path d="M16 6c-2.5 0-4 1.5-4 4"/></svg>`,
  },
  {
    title: "Low Fluorine",
    description:
      "Controlled mono-fluorination delivers the performance of fluorochemicals with minimal fluorine content.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v12"/><path d="M18 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M6 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M18 9v6a6 6 0 0 1-12 0"/></svg>`,
  },
  {
    title: "Durable",
    description:
      "Long-lasting fouling protection that maintains effectiveness between dry docking cycles.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
  {
    title: "Compatible",
    description:
      "Integrates seamlessly with standard binder systems used by major coating manufacturers.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  },
  {
    title: "Regulation-Aligned",
    description:
      "Designed to comply with EU and IMO regulations, including upcoming PFAS restrictions.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  },
]
---

<section id="solution" class="relative py-16 md:py-24">
  <div
    class="pointer-events-none inset-0"
    style="background: radial-gradient(ellipse 40% 50% at 20% 50%, oklch(0.5 0 0 / 0.04) 0%, transparent 70%);"
  >
    <div class="absolute inset-0 rotate-0">
      <LightRays
        client:load
        count={6}
        speed={5.7}
        blur={50}
        color="rgba( 211, 231, 255, 0.4)"
        className="z-10"
      />
    </div>
  </div>

  <div
    class="relative mx-auto flex max-w-7xl flex-col items-center gap-8 px-6 md:gap-12"
  >
    <div
      class="mx-auto flex flex-col items-center gap-4 text-center md:max-w-xl"
    >
      <Badge variant="section" className="mb-6">
        Our Solution
      </Badge>
      <h2
        class="font-display text-3xl font-normal tracking-tight text-foreground md:text-5xl"
      >
        A <span class="title-gradient">Biological</span> Alternative
      </h2>
      <p class="text-lg/8 text-pretty text-muted-foreground">
        BioHalo develops biotechnologically produced mono-fluorinated compounds
        as antifouling ingredients that are safe, effective, and future-proof.
      </p>
    </div>

    <div class="grid w-full max-w-5xl grid-cols-1 gap-3 lg:grid-cols-3">
      {
        features.map((feature) => (
          <Card className="flex flex-col gap-6 rounded-xl border bg-card py-6 text-card-foreground shadow-xs">
            <CardHeader className="flex flex-col items-start gap-2 px-6 py-0">
              <div class="mb-3 text-foreground [&>svg]:size-7">
                <Fragment set:html={feature.icon} />
              </div>
              <CardTitle className="text-xl font-semibold leading-none">
                {feature.title}
              </CardTitle>
              <CardDescription className="mt-2 text-pretty text-base text-muted-foreground">
                {feature.description}
              </CardDescription>
            </CardHeader>
          </Card>
        ))
      }
    </div>
  </div>
</section>
