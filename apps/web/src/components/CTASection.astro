---
import { Button } from "@workspace/ui/components/button"
import { FlickeringGrid } from "@workspace/ui/components/flickering-grid"
---

<section id="contact" class="relative py-16 md:py-24">
  <!-- Glow (neutral) -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 60% 60% at 50% 50%, oklch(0.5 0 0 / 0.05) 0%, transparent 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-screen-lg px-6 text-center">
    <div
      class="relative overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-b from-card to-background p-8 md:p-16"
    >
      <FlickeringGrid
        client:visible
        className="pointer-events-none absolute inset-0 z-0 [mask-image:radial-gradient(600px_circle_at_bottom_right,white,transparent)]"
        squareSize={4}
        gridGap={6}
        color="#a8e8e0"
        maxOpacity={0.45}
        flickerChance={0.1}
      />
      <h2
        class="font-display text-3xl font-normal tracking-tight text-foreground md:text-5xl"
      >
        Join Us in Building the Next Generation of
        <span class="title-gradient">Sustainable Coatings</span>
      </h2>
      <p
        class="mx-auto mt-4 max-w-xl text-base text-muted-foreground md:text-lg"
      >
        Whether you're a coating manufacturer, investor, or research partner,
        we'd love to explore how BioHalo can work for you.
      </p>

      <div
        class="mt-8 flex flex-col items-center justify-center gap-4 md:flex-row"
      >
        <a href="mailto:info@biohalo.io">
          <Button size="lg" className="h-12 px-8 text-base">
            Get in Touch
          </Button>
        </a>
        <a
          href="https://www.linkedin.com/company/biohalo"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Button
            variant="outline"
            size="lg"
            className="h-12 gap-2 px-8 text-base transition-all hover:border-teal/50 hover:bg-teal/5 hover:text-teal"
          >
            <svg
              class="size-4"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
            LinkedIn
          </Button>
        </a>
      </div>
    </div>
  </div>
</section>
