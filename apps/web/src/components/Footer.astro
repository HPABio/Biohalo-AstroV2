---
import logo from "../assets/images/BioHaloLogo.png"

const columns = [
  {
    title: "Our Solutions",
    links: [
      { label: "2-FMA", href: "#" },
      { label: "Technology", href: "#technology" },
      { label: "Hero", href: "#" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "#" },
      { label: "Team", href: "#team" },
      // { label: "Careers", href: "#" },
    ],
  },
  // {
  //   title: "Resources",
  //   links: [
  //     { label: "Publications", href: "#" },
  //     { label: "Patents", href: "#" },
  //     { label: "Press", href: "#" },
  //   ],
  // },
  {
    title: "Legal",
    links: [
      { label: "Privacy", href: "#" },
      { label: "Terms", href: "#" },
      { label: "Imprint", href: "#" },
    ],
  },
]
---

<footer class="relative border-t border-border/50">
  <div class="mx-auto max-w-screen-xl px-6 py-16 md:py-24">
    <div class="grid gap-8 md:grid-cols-6">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2">
          <img
            src={logo.src}
            alt="BioHalo"
            width={logo.width}
            height={logo.height}
            class="h-9 w-auto"
          />
          <span class="font-display text-lg font-semibold tracking-tight text-foreground">BioHalo</span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-muted-foreground">
          Pioneering sustainable marine chemistry through microbial biofluorination.
          Founded in Denmark, 2023.
        </p>
      </div>

      {columns.map((col) => (
        <div>
          <h4 class="mb-3 text-sm font-medium text-foreground">{col.title}</h4>
          <ul class="flex flex-col gap-2">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="my-8 h-px w-full bg-border"></div>

    <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
      <p class="text-xs text-muted-foreground">
        &copy; {new Date().getFullYear()} BioHalo ApS. All rights reserved.
      </p>
      <p class="text-xs text-muted-foreground">
        Copenhagen, Denmark
      </p>
    </div>
  </div>
</footer>
