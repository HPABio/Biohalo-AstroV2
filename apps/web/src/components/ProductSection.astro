---
import { Card, CardHeader, CardTitle, CardContent } from "@workspace/ui/components/card"
import { Badge } from "@workspace/ui/components/badge"

const traditional = [
  "High GHG emissions",
  "Fossil-derived feedstocks",
  "Toxic catalysts required",
  "High energy consumption",
  "Uncontrolled fluorination",
]

const biohalo = [
  "Controlled fluorination",
  "Low energy consumption",
  "Reduced pollutants",
  "Renewable feedstocks",
  "Minimal by-products",
]

const applications = [
  "Marine Coatings",
  "Polymer Industry",
  "Pharmaceutical",
  "Agrochemicals",
  "Conformal Coatings",
]
---

<section class="relative py-16 md:py-24">
  <div class="mx-auto max-w-screen-xl px-6">
    <div class="mb-8 text-center md:mb-16">
      <Badge variant="section" className="mb-4">Product</Badge>
      <h2 class="font-display text-3xl font-normal tracking-tight text-foreground md:text-5xl">
        2-FMA: Our <span class="title-gradient">Flagship</span> Product
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-muted-foreground md:text-lg">
        2-Fluoro-cis,cis-muconate — the first biologically produced mono-fluorinated
        building block. Extreme stereo purity, fermentation-based, previously
        impossible to synthesize chemically.
      </p>
    </div>

    <!-- Comparison -->
    <div class="mx-auto max-w-3xl flex flex-col md:flex-row gap-6 justify-center px-4">
      <Card className="border-none ring-1 ring-destructive/20 bg-gradient-to-br from-destructive/5 to-card/30 px-6 py-10 w-full md:w-fit min-w-[320px] flex flex-col items-center">
        <CardHeader className="p-0 mb-6 flex flex-col items-center text-center">
          <CardTitle className="flex items-center justify-center gap-2 text-xl font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0 text-destructive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            Traditional Fluorochemicals
          </CardTitle>
        </CardHeader>
        <CardContent className="p-0 w-full flex justify-center">
          <ul class="inline-flex flex-col gap-3">
            {traditional.map((item) => (
              <li class="flex items-center gap-3 text-sm text-muted-foreground whitespace-nowrap">
                <span class="size-1.5 shrink-0 rounded-full bg-destructive/50"></span>
                {item}
              </li>
            ))}
          </ul>
        </CardContent>
      </Card>

      <Card className="border-none ring-1 ring-primary/20 bg-gradient-to-br from-primary/5 to-card/30 px-6 py-10 w-full md:w-fit min-w-[320px] flex flex-col items-center">
        <CardHeader className="p-0 mb-6 flex flex-col items-center text-center">
          <CardTitle className="flex items-center justify-center gap-2 text-xl font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            BioHalo Technology
          </CardTitle>
        </CardHeader>
        <CardContent className="p-0 w-full flex justify-center">
          <ul class="inline-flex flex-col gap-3">
            {biohalo.map((item) => (
              <li class="flex items-center gap-3 text-sm text-foreground whitespace-nowrap">
                <span class="size-1.5 shrink-0 rounded-full bg-primary"></span>
                {item}
              </li>
            ))}
          </ul>
        </CardContent>
      </Card>
    </div>

    <!-- Applications -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-3">
      <span class="text-sm text-muted-foreground">Applications:</span>
      {applications.map((app) => (
        <Badge variant="secondary">{app}</Badge>
      ))}
    </div>
  </div>
</section>
