---
import { Badge } from "@workspace/ui/components/badge"
import TimeLine from "@workspace/ui/components/time-line"
---

<section id="roadmap" class="relative py-16 md:py-24">
  <div class="mx-auto max-w-screen-xl px-6">
    <div class="mb-8 text-center md:mb-16">
      <Badge variant="outline" className="mb-4">Roadmap</Badge>
      <h2 class="font-display text-3xl font-normal tracking-tight text-foreground md:text-5xl">
        Our <span class="title-gradient">Development</span> Roadmap
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-muted-foreground md:text-lg">
        An ambitious development timeline bringing sustainable antifouling from lab to global market.
      </p>
    </div>
    <TimeLine
      client:visible
      title=""
      subtitle=""
    />
  </div>
</section>
