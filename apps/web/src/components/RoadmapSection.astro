---
import { Badge } from "@workspace/ui/components/badge"
import TimeLine from "@workspace/ui/components/time-line"
---

<section id="roadmap" class="relative py-16 md:py-24">
  <div class="mx-auto max-w-screen-xl px-6">
    <div class="mb-8 text-center md:mb-16">
      <Badge variant="outline" className="mb-4">Roadmap</Badge>
    </div>
    <TimeLine
      client:visible
      title="Development Roadmap"
      subtitle="An ambitious development timeline bringing sustainable antifouling from lab to global market."
    />
  </div>
</section>
