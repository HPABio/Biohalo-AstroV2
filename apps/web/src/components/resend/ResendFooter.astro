---
/**
 * Resend-style footer (from Figma: address, social icons, Documentation / Resources / Company / Legal).
 */
const docLinks = [
  { label: "Getting Started", href: "/docs" },
  { label: "API Reference", href: "/docs/api" },
  { label: "Integrations", href: "/integrations" },
  { label: "Examples", href: "/examples" },
  { label: "SDKs", href: "/sdk" },
]
const resourceLinks = [
  { label: "Changelog", href: "/changelog" },
  { label: "Pricing", href: "/pricing" },
  { label: "Security", href: "/security" },
  { label: "SOC 2", href: "/soc2" },
  { label: "Status", href: "/status" },
]
const companyLinks = [
  { label: "Blog", href: "/blog" },
  { label: "Brand", href: "/brand" },
  { label: "Contact", href: "/contact" },
  { label: "Customers", href: "/customers" },
  { label: "Philosophy", href: "/philosophy" },
]
const legalLinks = [
  { label: "Acceptable Use", href: "/acceptable-use" },
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
]
const social = [
  { label: "Twitter", href: "https://twitter.com/resend", icon: "x" },
  { label: "GitHub", href: "https://github.com/resend", icon: "github" },
  { label: "LinkedIn", href: "https://linkedin.com/company/resend", icon: "linkedin" },
  { label: "Discord", href: "https://discord.gg/resend", icon: "discord" },
]
---

<footer class="relative border-t border-white/10 bg-black" data-figma-node="resend-footer">
  <!-- Gradient divider (from Figma) -->
  <div
    class="absolute left-[30%] right-[30%] top-0 h-px"
    style="background: linear-gradient(90deg, transparent 0%, rgba(143,143,143,0.67) 50%, transparent 100%);"
    aria-hidden="true"
  />

  <div class="mx-auto max-w-screen-xl px-6 py-16 md:px-[104px]">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-5">
      <!-- Address + social -->
      <div class="lg:col-span-1">
        <p class="text-xs leading-relaxed text-muted-foreground">
          2261 Market Street #5039<br />San Francisco, CA 94114
        </p>
        <div class="mt-6 flex gap-3">
          {social.map(({ label, href }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground transition-colors hover:text-foreground"
              aria-label={label}
            >
              <span class="inline-flex size-8 items-center justify-center rounded border border-white/10 text-sm">{label.slice(0, 1)}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Documentation -->
      <div>
        <h4 class="text-sm font-medium text-foreground">Documentation</h4>
        <ul class="mt-3 flex flex-col gap-2">
          {docLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-medium text-foreground">Resources</h4>
        <ul class="mt-3 flex flex-col gap-2">
          {resourceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-sm font-medium text-foreground">Company</h4>
        <ul class="mt-3 flex flex-col gap-2">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-medium text-foreground">Legal</h4>
        <ul class="mt-3 flex flex-col gap-2">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="mt-12 text-xs text-muted-foreground">
      © {new Date().getFullYear()} Resend, Inc. All rights reserved.
    </p>
  </div>
</footer>
