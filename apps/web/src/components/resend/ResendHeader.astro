---
/**
 * Resend-style header (from Figma Resend.com → Web Pages UI).
 * Backdrop blur, border, logo left, nav center, Sign in + Get Started right.
 */
import { Button } from "@workspace/ui/components/button"

const navLinks = [
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
  { href: "/customers", label: "Customers" },
  { href: "/pricing", label: "Pricing" },
  { href: "/enterprise", label: "Enterprise" },
  { href: "/changelog", label: "Changelog" },
  { href: "/docs", label: "Docs" },
]
---

<header
  class="fixed top-0 left-0 right-0 z-40 border-b border-white/10 bg-black/50 backdrop-blur-[2px]"
  data-figma-node="resend-header"
>
  <div class="mx-auto flex h-14 max-w-screen-xl items-center justify-between px-6 md:px-[104px]">
    <a href="/" class="flex items-center gap-2 text-foreground">
      <span class="font-display text-lg font-semibold tracking-tight">Resend</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a
        href="/signin"
        class="text-sm font-semibold text-muted-foreground transition-colors hover:text-foreground"
      >
        Sign in
      </a>
      <a href="/signup">
        <Button size="sm" className="h-10 rounded-full bg-white px-5 text-black hover:bg-white/90">
          Get Started
          <span class="ml-1.5 inline-block size-4">→</span>
        </Button>
      </a>
    </div>
  </div>
</header>
