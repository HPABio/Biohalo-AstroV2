---
/**
 * Resend-style "Code Integration" section: headline, CTAs, vertical API tabs + code panel.
 * Rebuild of resend.com section: dot grid background, "Integrate your audience with code", Create/Unsubscribe/Delete contact tabs.
 */
const codeCreate = `import { Resend } from 'resend';

const resend = new Resend('re_xxxxxxxxx');

await resend.contacts.create({
  email: 'acme@example.com',
  audienceId: '78261eea-8f8b-438f-8a78-421d1c2b6b5d',
  firstName: 'John',
  lastName: 'Doe',
});`

const codeUnsubscribe = `import { Resend } from 'resend';

const resend = new Resend('re_xxxxxxxxx');

await resend.contacts.update({
  id: '520784e2-887d-4c25-b53c-4ad46ad38100',
  unsubscribed: true,
});`

const codeDelete = `import { Resend } from 'resend';

const resend = new Resend('re_xxxxxxxxx');

// Delete by contact id
await resend.contacts.remove({
  id: '520784e2-887d-4c25-b53c-4ad46ad38100',
});

// Delete by contact email
await resend.contacts.remove({
  email: 'acme@example.com',
});`
---

<section
  class="relative mx-auto mt-[calc(10vh-2rem)] flex w-full flex-col items-center justify-center overflow-hidden px-0 py-10 sm:py-24"
  data-figma-node="resend-integration"
>
  <!-- Dot grid background (masked) -->
  <div
    class="absolute left-1/2 top-1/2 h-[calc(100%+2rem)] w-[112vw] -translate-x-1/2 -translate-y-1/2 overflow-hidden"
    style="mask-image: linear-gradient(to top, rgba(0, 0, 0, 0) 0%, rgb(0, 0, 0) 15%, rgb(0, 0, 0) 85%, rgba(0, 0, 0, 0) 100%);"
  >
    <div
      class="absolute inset-0 bg-[radial-gradient(#2B2B2B_1px,transparent_1px)] [background-size:16px_16px]"
      style="mask-image: linear-gradient(to right, rgba(0, 0, 0, 0) 0%, rgb(0, 0, 0) 30%, rgb(0, 0, 0) 70%, rgba(0, 0, 0, 0) 100%);"
    />
  </div>

  <!-- Header -->
  <div class="z-10 mb-8 flex flex-col items-center justify-center text-center md:mb-16">
    <span class="[&>svg]:stroke-[1.5] [&>svg]:w-[18px] mb-6 flex items-center justify-center gap-2 bg-gradient-to-r from-foreground to-muted-foreground bg-clip-text text-transparent [&>svg]:text-muted-foreground">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="8" height="8" x="3" y="3" rx="2" />
        <path d="M7 11v4a2 2 0 0 0 2 2h4" />
        <rect width="8" height="8" x="13" y="13" rx="2" />
      </svg>
      Code Integration
    </span>
    <h2 class="font-display effect-font-styling effect-font-hero effect-font-gradient relative mb-2 text-[3rem] font-normal leading-[120%] tracking-tighter text-foreground md:text-[3.5rem]">
      Integrate your<br class="hidden sm:block" /> audience with code
    </h2>
    <p class="text-balance text-base font-normal text-muted-foreground md:text-[1.125rem] md:leading-[1.5]">
      Add the logic to create, update, unsubscribe,<br class="hidden sm:block" />
      and remove contacts directly into your application.
    </p>
    <div class="mx-auto mt-8 flex flex-col justify-center gap-4 sm:flex-row">
      <a
        href="https://resend.com/docs/api-reference/contacts/create-contact"
        class="focus-visible:bg-white/90 focus-visible:text-black focus-visible:ring-4 focus-visible:ring-white/30 focus-visible:outline-hidden not-disabled:hover:bg-white/90 not-disabled:hover:text-black not-disabled:hover:shadow-button relative inline-flex h-12 select-none items-center justify-center rounded-2xl border-[2px] border-white/5 bg-[linear-gradient(104deg,rgba(253,253,253,0.05)_5%,rgba(240,240,228,0.1)_100%)] bg-origin-border px-5 text-base font-semibold text-white shadow-sm backdrop-blur-[25px] transition-all duration-200 ease-in-out disabled:cursor-not-allowed disabled:opacity-30 disabled:text-white/50 after:absolute after:left-[-2px] after:top-[-2px] after:h-[calc(100%+4px)] after:w-[calc(100%+4px)] after:rounded-[1rem] after:bg-[url('/static/texture-btn.png')] after:bg-repeat after:pointer-events-none"
      >
        See API Docs
        <span class="-mr-2 opacity-100 text-[#70757E] transition-all group-hover:invert-100">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.75 8.75L14.25 12L10.75 15.25" />
          </svg>
        </span>
      </a>
      <a
        href="/api-keys"
        class="focus-visible:ring-4 focus-visible:ring-gray-a2 focus-visible:outline-hidden inline-flex h-12 items-center justify-center gap-0 rounded-2xl border border-transparent bg-transparent px-5 text-base font-semibold text-muted-foreground transition duration-200 ease-in-out hover:text-foreground disabled:cursor-not-allowed disabled:opacity-70 [&_svg]:text-muted-foreground"
      >
        Get API Key
        <span class="-mr-2 opacity-100 text-[#70757E] transition-all group-hover:invert-100">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.75 8.75L14.25 12L10.75 15.25" />
          </svg>
        </span>
      </a>
    </div>
  </div>

  <!-- Tabs + Code panel -->
  <div class="relative z-10 w-full pb-24 md:px-32">
    <div class="integration-tabs relative flex w-full flex-col items-stretch justify-start gap-[.875rem] md:flex-row md:gap-9" data-integration-tabs>
      <!-- Tab list -->
      <div
        role="tablist"
        aria-orientation="vertical"
        class="flex w-full flex-col gap-[.875rem] md:w-[30%] md:min-w-[24rem] md:max-w-[27.5rem]"
      >
        <button
          type="button"
          role="tab"
          aria-selected="false"
          aria-controls="integration-content-create"
          id="integration-trigger-create"
          data-tab="create"
          class="integration-tab relative w-full overflow-hidden rounded-xl border border-solid border-white/10 p-px transition-colors"
        >
          <div class="relative flex flex-col items-start justify-start overflow-hidden rounded-xl bg-black p-6 pr-10">
            <div class="flex w-full flex-row items-center justify-between gap-3">
              <div class="flex flex-row items-center justify-center gap-3">
                <div class="integration-tab-icon [&>svg]:stroke-[1.5px] flex h-10 w-10 items-center justify-center overflow-hidden rounded-xl border border-solid border-white/20 bg-transparent transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <line x1="19" x2="19" y1="8" y2="14" />
                    <line x1="22" x2="16" y1="11" y2="11" />
                  </svg>
                </div>
                <h3 class="font-display text-lg font-medium">Create contact</h3>
              </div>
              <span class="relative -mr-[.75rem] flex items-center justify-center px-3 py-1.5 text-xs font-semibold leading-4" style="color: rgb(0, 144, 255);">POST</span>
            </div>
            <p class="integration-tab-desc mt-2 text-left text-sm leading-6 text-white/60">
              Add a new contact to your audience with the properties you need.
            </p>
          </div>
        </button>

        <button
          type="button"
          role="tab"
          aria-selected="false"
          aria-controls="integration-content-unsubscribe"
          id="integration-trigger-unsubscribe"
          data-tab="unsubscribe"
          class="integration-tab relative w-full overflow-hidden rounded-xl border border-solid border-white/10 p-px transition-colors"
        >
          <div class="relative flex flex-col items-start justify-start overflow-hidden rounded-xl bg-black p-6 pr-10">
            <div class="flex w-full flex-row items-center justify-between gap-3">
              <div class="flex flex-row items-center justify-center gap-3">
                <div class="integration-tab-icon [&>svg]:stroke-[1.5px] flex h-10 w-10 items-center justify-center overflow-hidden rounded-xl border border-solid border-white/20 bg-transparent transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M10 15H6a4 4 0 0 0-4 4v2" />
                    <path d="m14.305 16.53.923-.382" />
                    <path d="m15.228 13.852-.923-.383" />
                    <path d="m16.852 12.228-.383-.923" />
                    <path d="m16.852 17.772-.383.924" />
                    <path d="m19.148 12.228.383-.923" />
                    <path d="m19.53 18.696-.382-.924" />
                    <path d="m20.772 13.852.924-.383" />
                    <path d="m20.772 16.148.924.383" />
                    <circle cx="18" cy="15" r="3" />
                    <circle cx="9" cy="7" r="4" />
                  </svg>
                </div>
                <h3 class="font-display text-lg font-medium">Unsubscribe contact</h3>
              </div>
              <span class="relative -mr-[.75rem] flex items-center justify-center px-3 py-1.5 text-xs font-semibold leading-4" style="color: rgb(247, 107, 21);">PATCH</span>
            </div>
            <p class="integration-tab-desc mt-2 text-left text-sm leading-6 text-white/60 opacity-0 h-0 overflow-hidden">
              Change a property of an existing contact, such as the subscription status.
            </p>
          </div>
        </button>

        <button
          type="button"
          role="tab"
          aria-selected="true"
          aria-controls="integration-content-delete"
          id="integration-trigger-delete"
          data-tab="delete"
          class="integration-tab integration-tab-active relative w-full overflow-hidden rounded-xl border border-solid border-white/10 p-px transition-colors"
        >
          <div class="integration-tab-glow absolute inset-0 overflow-hidden rounded-xl" aria-hidden="true">
            <div class="pointer-events-none absolute inset-0 rounded-[inherit] border border-transparent [mask-clip:padding-box,border-box] [mask-composite:intersect] [mask-image:linear-gradient(transparent,transparent),linear-gradient(#000,#000)]">
              <div class="integration-tab-glow-dot absolute aspect-square bg-red-500/80 rounded-full" style="width: 42px; box-shadow: 0px 0px 60px 30px rgba(185, 28, 28, 0.4);" />
            </div>
          </div>
          <div class="relative flex flex-col items-start justify-start overflow-hidden rounded-xl bg-black p-6 pr-10">
            <div class="flex w-full flex-row items-center justify-between gap-3">
              <div class="flex flex-row items-center justify-center gap-3">
                <div class="integration-tab-icon [&>svg]:stroke-[1.5px] [&>svg]:text-red-400 flex h-10 w-10 items-center justify-center overflow-hidden rounded-xl border border-solid border-white/20 bg-gradient-to-br from-white/10 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <line x1="22" x2="16" y1="11" y2="11" />
                  </svg>
                </div>
                <h3 class="font-display text-lg font-medium">Delete contact</h3>
              </div>
              <span class="relative -mr-[.75rem] flex items-center justify-center px-3 py-1.5 text-xs font-semibold leading-4" style="color: rgb(229, 72, 77);">DEL</span>
            </div>
            <p class="integration-tab-desc mt-2 text-left text-sm leading-6 text-white/60">
              Remove a contact from your audience. This action is irreversible.
            </p>
          </div>
        </button>
      </div>

      <!-- Code panel -->
      <div class="relative min-w-0 flex-1">
        <div class="integration-content w-full h-full" data-integration-content>
          <div
            id="integration-content-create"
            role="tabpanel"
            aria-labelledby="integration-trigger-create"
            class="integration-panel hidden h-full w-full min-h-[24rem] max-h-[24rem]"
            data-panel="create"
          >
            <div class="relative flex h-full min-h-[24rem] max-h-[24rem] w-full flex-col overflow-hidden self-center rounded-3xl border border-white/10 bg-black text-sm shadow-sm">
              <div class="relative z-[3] flex min-h-0 w-full flex-1 flex-col gap-3 overflow-auto rounded-3xl border border-white/10 bg-black pt-3">
                <div class="relative flex flex-row items-center justify-between gap-2 pl-4 pr-3">
                  <div class="pointer-events-none grid grid-flow-row grid-cols-3 gap-[.375rem]" aria-hidden="true">
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                  </div>
                  <button type="button" class="flex h-8 items-center justify-center gap-1 overflow-hidden rounded-xl border border-solid border-white/12 bg-black py-2 pl-3 pr-[.625rem] leading-5 text-muted-foreground outline-none" aria-label="Select SDK">
                    Node.js
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </button>
                </div>
                <div class="disable-children-scrolling relative z-20 min-h-0 w-full flex-1 overflow-auto rounded-[.25rem] bg-transparent selection:bg-white/20 selection:text-white">
                  <pre class="relative h-full overflow-auto py-4 pr-2.5 pl-3.5 text-sm text-[rgb(235,236,237)]"><code>{codeCreate}</code></pre>
                </div>
              </div>
            </div>
          </div>

          <div
            id="integration-content-unsubscribe"
            role="tabpanel"
            aria-labelledby="integration-trigger-unsubscribe"
            class="integration-panel hidden h-full w-full min-h-[24rem] max-h-[24rem]"
            data-panel="unsubscribe"
          >
            <div class="relative flex h-full min-h-[24rem] max-h-[24rem] w-full flex-col overflow-hidden self-center rounded-3xl border border-white/10 bg-black text-sm shadow-sm">
              <div class="relative z-[3] flex min-h-0 w-full flex-1 flex-col gap-3 overflow-auto rounded-3xl border border-white/10 bg-black pt-3">
                <div class="relative flex flex-row items-center justify-between gap-2 pl-4 pr-3">
                  <div class="pointer-events-none grid grid-flow-row grid-cols-3 gap-[.375rem]" aria-hidden="true">
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                  </div>
                  <button type="button" class="flex h-8 items-center justify-center gap-1 overflow-hidden rounded-xl border border-solid border-white/12 bg-black py-2 pl-3 pr-[.625rem] leading-5 text-muted-foreground outline-none" aria-label="Select SDK">
                    Node.js
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </button>
                </div>
                <div class="disable-children-scrolling relative z-20 min-h-0 w-full flex-1 overflow-auto rounded-[.25rem] bg-transparent selection:bg-white/20 selection:text-white">
                  <pre class="relative h-full overflow-auto py-4 pr-2.5 pl-3.5 text-sm text-[rgb(235,236,237)]"><code>{codeUnsubscribe}</code></pre>
                </div>
              </div>
            </div>
          </div>

          <div
            id="integration-content-delete"
            role="tabpanel"
            aria-labelledby="integration-trigger-delete"
            class="integration-panel flex h-full w-full min-h-[24rem] max-h-[24rem]"
            data-panel="delete"
          >
            <div class="relative flex h-full min-h-[24rem] max-h-[24rem] w-full flex-col overflow-hidden self-center rounded-3xl border border-white/10 bg-black text-sm shadow-sm">
              <div class="relative z-[3] flex min-h-0 w-full flex-1 flex-col gap-3 overflow-auto rounded-3xl border border-white/10 bg-black pt-3">
                <div class="relative flex flex-row items-center justify-between gap-2 pl-4 pr-3">
                  <div class="pointer-events-none grid grid-flow-row grid-cols-3 gap-[.375rem]" aria-hidden="true">
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                    <span class="h-[.625rem] w-[.625rem] rounded-full border border-solid border-white/20" />
                  </div>
                  <button type="button" class="flex h-8 items-center justify-center gap-1 overflow-hidden rounded-xl border border-solid border-white/12 bg-black py-2 pl-3 pr-[.625rem] leading-5 text-muted-foreground outline-none" aria-label="Select SDK">
                    Node.js
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m6 9 6 6 6-6" />
                    </svg>
                  </button>
                </div>
                <div class="disable-children-scrolling relative z-20 min-h-0 w-full flex-1 overflow-auto rounded-[.25rem] bg-transparent selection:bg-white/20 selection:text-white">
                  <pre class="relative h-full overflow-auto py-4 pr-2.5 pl-3.5 text-sm text-[rgb(235,236,237)]"><code>{codeDelete}</code></pre>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initIntegrationTabs() {
    const container = document.querySelector('[data-integration-tabs]')
    if (!container) return

    const tabs = container.querySelectorAll('.integration-tab')
    const panels = container.querySelectorAll('.integration-panel')

    /** @param {string} tabId */
    // @ts-expect-error - script in .astro has no TS syntax for param types
    function setActive(tabId) {
      tabs.forEach((tab) => {
        const id = tab.getAttribute('data-tab')
        const desc = tab.querySelector('.integration-tab-desc')
        const glow = tab.querySelector('.integration-tab-glow')
        const glowDot = tab.querySelector('.integration-tab-glow-dot')
        const iconBox = tab.querySelector('.integration-tab-icon')

        if (id === tabId) {
          tab.setAttribute('aria-selected', 'true')
          tab.classList.add('integration-tab-active')
          if (desc instanceof HTMLElement) {
            desc.style.height = 'auto'
            desc.style.opacity = '1'
            desc.classList.remove('h-0', 'overflow-hidden', 'opacity-0')
          }
          if (glow instanceof HTMLElement) glow.classList.remove('hidden')
          if (glowDot instanceof HTMLElement) glowDot.style.opacity = '1'
          if (iconBox) iconBox.classList.add('bg-gradient-to-br', 'from-white/10', '[&>svg]:text-red-400')
        } else {
          tab.setAttribute('aria-selected', 'false')
          tab.classList.remove('integration-tab-active')
          if (desc instanceof HTMLElement) {
            desc.style.height = '0'
            desc.style.opacity = '0'
            desc.classList.add('h-0', 'overflow-hidden', 'opacity-0')
          }
          if (glow instanceof HTMLElement) glow.classList.add('hidden')
          if (glowDot instanceof HTMLElement) glowDot.style.opacity = '0'
          if (iconBox) iconBox.classList.remove('bg-gradient-to-br', 'from-white/10', '[&>svg]:text-red-400')
        }
      })

      panels.forEach((panel) => {
        if (panel.getAttribute('data-panel') === tabId) {
          panel.classList.remove('hidden')
          panel.classList.add('flex')
        } else {
          panel.classList.add('hidden')
          panel.classList.remove('flex')
        }
      })
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.getAttribute('data-tab')
        if (id) setActive(id)
      })
    })
  }

  initIntegrationTabs()
</script>

<style>
  .integration-tab-desc {
    transition: height 0.2s ease, opacity 0.2s ease;
  }
  .integration-tab:not(.integration-tab-active) .integration-tab-glow {
    display: none;
  }
  .integration-tab-active .integration-tab-glow-dot {
    opacity: 1;
  }
  /* Fallback when effect-font-* are not defined */
  .effect-font-styling,
  .effect-font-gradient,
  .effect-font-hero {
    background: linear-gradient(to bottom right, rgb(255 255 255) 30%, rgba(255, 255, 255, 0.5));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
</style>
