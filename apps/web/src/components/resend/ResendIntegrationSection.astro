---
/**
 * Resend-style "Integrate this morning" section with headline, subtext, and code tabs.
 * From Figma: golden gradient on "this morning", SDK tabs (Node, Serverless, Ruby, etc.), code panel.
 */
interface Props {
  /** Tab labels for SDK/framework switcher */
  tabs?: { id: string; label: string }[]
}

const { tabs = [
  { id: "node", label: "Node.js" },
  { id: "serverless", label: "Serverless" },
  { id: "ruby", label: "Ruby" },
  { id: "python", label: "Python" },
  { id: "php", label: "PHP" },
  { id: "go", label: "Go" },
  { id: "java", label: "Java" },
  { id: "elixir", label: "Elixir" },
  { id: "rest", label: "REST" },
  { id: "smtp", label: "SMTP" },
] } = Astro.props

const codeSnippet = `import { Resend } from 'resend';

const resend = new Resend('re_123');

await resend.emails.send({
  from: 'onboarding@resend.dev',
  to: 'user@example.com',
  subject: 'Hello',
  html: '<p>Hello world</p>',
});`
---

<section class="relative py-24 md:py-32" data-figma-node="resend-integration">
  <div class="mx-auto max-w-screen-xl px-6 md:px-[104px]">
    <div class="flex flex-col items-center text-center">
      <h2 class="font-display text-4xl font-normal tracking-tight text-foreground md:text-5xl">
        Integrate <span class="title-gradient">this morning</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-muted-foreground">
        A simple, elegant interface so you can start sending emails in minutes. It fits right into your code with SDKs for your favorite programming languages.
      </p>
    </div>

    <!-- Tab row (simplified: no client JS, first tab "active" by default) -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-2">
      {tabs.map((tab, i) => (
        <button
          type="button"
          class={`rounded-2xl border px-4 py-3 text-sm transition-colors ${
            i === 0
              ? "border-white/20 bg-white/5 text-foreground"
              : "border-white/10 text-muted-foreground hover:text-foreground"
          }`}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Code panel -->
    <div class="mt-6 overflow-hidden rounded-2xl border border-white/10 bg-card/30">
      <div class="flex border-b border-white/10 px-4 py-3">
        <span class="rounded bg-white/10 px-2 py-1 text-xs text-muted-foreground">index.tsx</span>
      </div>
      <pre class="overflow-x-auto p-6 text-sm text-muted-foreground"><code>{codeSnippet}</code></pre>
    </div>
  </div>
</section>
