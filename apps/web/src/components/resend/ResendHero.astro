---
/**
 * Resend-style hero (from Figma: "Email for developers" with 3D cube visual).
 * Headline, subtext, Get started + Learn more CTAs.
 */
import { Button } from "@workspace/ui/components/button"
---

<section class="relative flex min-h-svh items-center justify-center overflow-hidden pt-14" data-figma-node="resend-hero">
  <!-- Subtle gradient (neutral) -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 70% 50% at 50% 30%, oklch(0.45 0 0 / 0.1) 0%, transparent 60%);"
  />

  <div class="relative z-10 mx-auto max-w-screen-xl px-6 py-24 text-center md:py-32">
    <h1 class="font-display text-5xl font-normal leading-[1.1] tracking-[-0.02em] text-foreground md:text-6xl lg:text-7xl">
      Email for <span class="title-gradient">developers</span>.
    </h1>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-muted-foreground">
      The best way to build, test, and send emails that developers love.
    </p>
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href="/signup">
        <Button size="lg" className="h-12 rounded-full bg-white px-8 text-base text-black hover:bg-white/90">
          Get started
          <span class="ml-2 inline-block size-5">→</span>
        </Button>
      </a>
      <a href="/docs">
        <Button variant="outline" size="lg" className="h-12 rounded-full border-white/30 px-8 text-base">
          Learn more
        </Button>
      </a>
    </div>
    <!-- Optional: placeholder for 3D cube / visual (design had isometric cube with glow) -->
    <div class="mt-16 flex justify-center">
      <div
        class="size-48 rounded-2xl border border-white/10 bg-white/5 md:size-64"
        aria-hidden="true"
      />
    </div>
  </div>
</section>
