---
import { Button } from "@workspace/ui/components/button"
import { MobileNav } from "./MobileNav"

const links = [
  { href: "#problem", label: "Problem" },
  { href: "#solution", label: "Solution" },
  { href: "#technology", label: "Technology" },
  { href: "#roadmap", label: "Roadmap" },
  { href: "#team", label: "Team" },
]
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-all duration-300"
>
  <div class="mx-auto flex max-w-screen-xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2">
      <div class="flex size-9 items-center justify-center rounded-lg bg-primary">
        <span class="font-display text-lg font-bold text-primary-foreground">B</span>
      </div>
      <span class="font-display text-xl font-semibold tracking-tight text-foreground">BioHalo</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class="rounded-lg px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="#contact" class="hidden md:block">
        <Button size="sm">Get in Touch</Button>
      </a>
      <MobileNav client:load />
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header")
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 50) {
        header.classList.add("bg-background/80", "backdrop-blur-lg", "border-b", "border-border")
      } else {
        header.classList.remove("bg-background/80", "backdrop-blur-lg", "border-b", "border-border")
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true })
    onScroll()
  }
</script>
