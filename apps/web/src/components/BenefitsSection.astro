import { Badge } from "@workspace/ui/components/badge"

function dotGrid(opacity = 0.08): string {
  let circles = ""
  for (let row = 0; row < 7; row++) {
    for (let col = 0; col < 8; col++) {
      circles += `<circle cx="${10 + col * 52}" cy="${10 + row * 38}" r="0.8" fill="rgba(121, 203, 195,${opacity})"/>`
    }
  }
  return circles
}

