---

<section id="benefits" class="relative py-16 md:py-24">
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 50% 40% at 50% 60%, oklch(0.5 0.1 185 / 0.04) 0%, transparent 70%);"
  ></div>

  <div class="relative mx-auto max-w-screen-xl px-6">
    <!-- Section header -->
    <div class="mb-10 md:mb-16">
      <Badge variant="outline" className="mb-4">Technology</Badge>
      <h2 class="max-w-2xl font-display text-3xl font-normal tracking-tight text-foreground md:text-5xl">
        Microbial <span class="title-gradient">Biofluorination</span>
      </h2>
      <p class="mt-4 max-w-xl text-base text-muted-foreground md:text-lg">
        A breakthrough platform that uses microorganisms to perform controlled
        mono-fluorination — producing compounds previously impossible to synthesize.
      </p>
    </div>

    <!-- Process cards -->
    <div class="flex flex-col">
      {cards.map((card, i) => (
        <>
          <div class:list={[
            "flex flex-col overflow-hidden rounded-2xl ",
            card.illustrationLeft ? "md:flex-row" : "md:flex-row-reverse",
          ]}>
            <!-- Illustration panel -->
            <div class="illustration-panel relative flex items-center justify-center overflow-hidden p-4 md:w-[52%]">
              <div
                class="pointer-events-none absolute inset-0"
                style={`background: radial-gradient(ellipse at ${card.illustrationLeft ? "60%" : "40%"} 50%, oklch(0.75 0.15 185 / 0.06) 0%, transparent 65%);`}
              ></div>
              <div class="relative w-full max-w-[380px]">
                <Fragment set:html={illustrations[card.illustration]} />
              </div>
            </div>

            <!-- Content panel -->
            <div class="flex flex-1 flex-col justify-center gap-5 p-8 md:px-10 md:py-11 lg:px-12">
              <div class="flex items-center gap-2.5">
                <span class="font-mono text-xs tracking-wider text-primary/45">{card.step}</span>
                <Badge variant="outline">{card.badge}</Badge>
              </div>

              <h3 class="font-display text-2xl font-semibold tracking-tight text-foreground md:text-[clamp(1.5rem,2.4vw,2.125rem)]">
                {card.title}
              </h3>

              <p class="max-w-sm text-sm leading-relaxed text-muted-foreground">
                {card.description}
              </p>

              {card.bullets && (
                <ul class="mt-1 flex flex-col gap-3">
                  {card.bullets.map((b) => (
                    <li class="flex items-center gap-3">
                      <span class="flex size-[22px] shrink-0 items-center justify-center rounded-full border border-primary text-primary">
                        <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
                          <path d="M1.5 6L4.5 9.5L10.5 2.5" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span class="text-sm text-foreground/70">{b}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>

          <!-- Connector line between cards -->
          {i < cards.length - 1 && (
            <div class="mx-auto hidden w-3/4 md:block">
              <svg width="100%" height="56" viewBox="0 0 1100 56" preserveAspectRatio="none" fill="none">
                {card.illustrationLeft
                  ? <path d="M1100 0 Q1100 28 1060 28 L40 28 Q0 28 0 56" stroke="oklch(0.75 0.15 185 / 0.22)" stroke-width="1" stroke-dasharray="6,5" fill="none" vector-effect="non-scaling-stroke"/>
                  : <path d="M0 0 Q0 28 40 28 L1060 28 Q1100 28 1100 56" stroke="oklch(0.75 0.15 185 / 0.22)" stroke-width="1" stroke-dasharray="6,5" fill="none" vector-effect="non-scaling-stroke"/>
                }
              </svg>
            </div>
          )}
        </>
      ))}
    </div>

    <!-- Stats bar -->
    <div class="mt-12 grid gap-px overflow-hidden rounded-2xl ring-1 ring-border/50 sm:grid-cols-2 md:grid-cols-4">
      {stats.map((s, i) => (
        <div class:list={[
          "flex flex-col gap-2 bg-card/30 p-6 md:p-7",
          i < stats.length - 1 && "border-b border-border/30 md:border-r md:border-b-0",
        ]}>
          <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">{s.label}</span>
          <span class="font-display text-lg font-semibold text-primary">{s.value}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .illustration-panel {
    background: oklch(0.10 0.02 185 / 0.97);
  }
</style>
